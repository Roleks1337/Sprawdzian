{
  "name": "school/php-docker-actions",
  "description": "Prosta aplikacja PHP do sprawdzianu z GitHub Actions i Dockera",
  "type": "project",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=PSR12 src public tests",
    "test": "phpunit --colors=never --testdox tests",
    "test:junit": "phpunit --colors=never --log-junit build/junit.xml tests"
  }
}
